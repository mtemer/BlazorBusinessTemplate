<div class="mt-empty-state" role="status">

    @if (Icon is not null)
    {
        <div class="mt-empty-state__icon">
            @Icon
        </div>
    }

    @if (Title is not null)
    {
        <div class="mt-empty-state__title">
            @Title
        </div>
    }

    @if (Description is not null)
    {
        <div class="mt-empty-state__description">
            @Description
        </div>
    }

    @if (Actions is not null)
    {
        <div class="mt-empty-state__actions">
            @Actions
        </div>
    }

</div>

@code
{
    /// <summary>
    /// Gets or sets the optional icon content.
    /// </summary>
    [Parameter]
    public RenderFragment? Icon { get; set; }

    /// <summary>
    /// Gets or sets the title content.
    /// </summary>
    [Parameter]
    public RenderFragment? Title { get; set; }

    /// <summary>
    /// Gets or sets the description content.
    /// </summary>
    [Parameter]
    public RenderFragment? Description { get; set; }

    /// <summary>
    /// Gets or sets optional action content.
    /// </summary>
    [Parameter]
    public RenderFragment? Actions { get; set; }
}